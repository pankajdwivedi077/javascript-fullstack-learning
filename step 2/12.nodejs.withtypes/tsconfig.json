{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",
    "module": "nodenext", 
    "moduleResolution": "nodenext", 
    "target": "esnext",
    "types": ["node"], 
    "lib": ["esnext"],
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,
    "strict": true,
    "jsx": "react-jsx",
    "skipLibCheck": true
  }
}